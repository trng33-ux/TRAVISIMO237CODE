scene.onOverlapTile(SpriteKind.Player, assets.tile`myTile`, function (sprite, location) {
    story.startCutscene(function () {
        effects.starField.startScreenEffect(5000)
        story.printCharacterText("This vidio says the world is flat like a pancake!!- Is this true?", "A Shocking Video!!")
        story.showPlayerChoices("True!", "Nah", "Possible ")
        if (story.checkLastAnswer("True!")) {
            mySprite.x += -10
            info.changeScoreBy(1)
        } else {
            mySprite.x += -10
            info.changeScoreBy(-1)
        }
    })
})
